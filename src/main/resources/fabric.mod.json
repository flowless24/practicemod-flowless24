{
	"schemaVersion": 1,
	"id": "practicemod",
	"version": "${version}",
	"name": "PracticeMod",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Flowless24"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/practicemod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"flowless24.practicemod.PracticeMod"
		],
		"fabric-datagen": [
			"flowless24.practicemod.PracticeModDataGenerator"
		],
        "client": [
            "flowless24.practicemod.PracticeModClient"
        ]
	},
	"mixins": [
		"practicemod.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	}
}